    "n_arange = np.arange(0,1000,1)\n",
    "def symmetrische_irrfahrt (n,start):\n",
    "    steps=[]\n",
    "    step=start\n",
    "    for i in range (n):\n",
    "        u=r.random()\n",
    "        if 0<=u<=0.5:\n",
    "            step -= 1\n",
    "        elif 0.5<u<=1:\n",
    "            step +=1\n",
    "        steps.append(step)\n",
    "    return steps\n",
    "steps_drin= (symmetrische_irrfahrt(1000,10))\n",
    "plt.plot(n_arange,steps_drin)\n",
